# SECUREDATA Environment Configuration

# Security
SECRET_KEY=your-secret-key-change-in-production-min-32-characters-long
DEBUG=True

# Database
DATABASE_URL=sqlite:///./securedata.db

# JWT Settings
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# OTP Settings
OTP_EXPIRE_MINUTES=2

# Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=104857600

# CORS (comma-separated URLs)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Email SMTP Settings - For Gmail OTP
# ==========================================
# 1. Go to https://myaccount.google.com/apppasswords
# 2. Sign in to your Google Account
# 3. Select "Mail" and your device, then click "Generate"
# 4. Copy the 16-character app password (e.g., "abcd efgh ijkl mnop")
# 5. Paste it below (remove spaces)
# ==========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=gadivasu48@gmail.com
SMTP_PASSWORD=your-gmail-app-password-here
FROM_EMAIL=gadivasu48@gmail.com
